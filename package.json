{
  "name": "@fssou/camunda-mcp",
  "version": "0.1.0",
  "description": "MCP server with tools to author Camunda 7 BPMN diagrams, independent of the Camunda Modeler",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "camunda-mcp": "bin/camunda-mcp.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "camunda",
    "camunda7",
    "bpmn",
    "mcp",
    "model-context-protocol",
    "bpmn-js",
    "bpmn-moddle"
  ],
  "author": "Franclin <fssousa@outlook.com.br>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fssou/camunda-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/fssou/camunda-mcp/issues"
  },
  "homepage": "https://github.com/fssou/camunda-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bpmn-auto-layout": "^1.3.0",
    "bpmn-moddle": "^10.0.0",
    "camunda-bpmn-moddle": "^7.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
